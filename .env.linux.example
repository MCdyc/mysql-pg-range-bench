# Linux one-click launcher connection examples.
#
# Set these only for scripts/linux/run-existing-one-click.sh.
# Keep real passwords out of this tracked example and shell history. A private,
# permission-restricted shell profile or secret manager is preferable.
#
# Both dedicated, least-privilege accounts must be able to create/drop the
# tool's temporary databases and run table/index DDL, INSERT, SELECT, UPDATE
# (required by FOR UPDATE), and ANALYZE inside them. Restrict grants to the
# `codex_range_bench_` prefix where the server's privilege model permits it.
# The PostgreSQL role must also be able to terminate its sessions in that
# database. The URLs should end in an existing administrative database:
# `mysql` for MySQL and commonly `postgres`. Percent-encode URL-special
# characters in user names and passwords.

export MYSQL_ADMIN_URL='mysql://benchmark_admin:CHANGE_ME@127.0.0.1:3306/mysql'
export POSTGRES_ADMIN_URL='postgres://benchmark_admin:CHANGE_ME@127.0.0.1:5432/postgres'

# Optional SKIP LOCKED concurrency-test sizes. The candidate range must fit
# inside BENCH_SCAN_ROWS, and held rows must be smaller than candidate rows.
export BENCH_SKIP_LOCKED_ROWS=500
export BENCH_SKIP_LOCKED_HELD_ROWS=100

# Example:
#   export MYSQL_ADMIN_URL='mysql://...'
#   export POSTGRES_ADMIN_URL='postgres://...'
#   bash scripts/linux/run-existing-one-click.sh --smoke=100k/20k
#
# The launcher uses uniquely named temporary databases and removes them on
# normal completion, ordinary failure, and catchable termination signals. It
# does not change server configuration, users, or pre-existing databases.
# SIGKILL, host crashes, and lost administrator access cannot be cleaned up by
# any running program. Normal logs, counters, and cache contents can also
# change.

# Copy this file to .env before running Docker Compose.
# Change passwords if either port is exposed beyond localhost.
# Use a unique name for each checkout that shares the same Docker daemon.
COMPOSE_PROJECT_NAME=db-range-benchmark

# Pin patch versions so two runs do not silently use different server builds.
MYSQL_IMAGE=mysql:8.4.8
POSTGRES_IMAGE=postgres:17.10

DB_NAME=benchmark
DB_USER=benchmark
DB_PASSWORD=benchmark_password
MYSQL_ROOT_PASSWORD=local_root_password

MYSQL_PORT=3306
POSTGRES_PORT=5432

# The Rust program loads .env from the current directory. Keep these URLs in
# sync if you change DB_USER, DB_PASSWORD, or either port above. Percent-encode
# URL-special characters in credentials.
MYSQL_URL=mysql://benchmark:benchmark_password@127.0.0.1:3306/benchmark
POSTGRES_URL=postgres://benchmark:benchmark_password@127.0.0.1:5432/benchmark

# Keep these identical for both containers. Adjust for the Linux host.
DB_CPU_LIMIT=4.0
DB_MEMORY_LIMIT=4g
# Equal to DB_MEMORY_LIMIT: disable container swap for stable latency.
DB_MEMORY_SWAP_LIMIT=4g

# PostgreSQL uses shared memory for parallel queries. This remains inside the
# container memory limit above.
POSTGRES_SHM_SIZE=1g

# Startup health wait and disk-space warning thresholds.
COMPOSE_WAIT_TIMEOUT=300
BENCH_RECOMMENDED_FREE_GIB=50

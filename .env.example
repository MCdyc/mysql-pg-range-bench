# Optional settings for the project-local Linux instances.
# Copy to .env only when overriding these defaults. Credentials are generated
# automatically in .local-db/credentials.env and must not be placed here.

# Pin patch versions so two runs do not silently use different server builds.
# The Linux scripts automatically download either image when it is missing.
MYSQL_IMAGE=mysql:8.4.8
POSTGRES_IMAGE=postgres:17.10

LOCAL_MYSQL_PORT=13306
LOCAL_POSTGRES_PORT=15432
LOCAL_COMPOSE_WAIT_TIMEOUT=300

# Keep these identical for both containers. Adjust for the Linux host.
DB_CPU_LIMIT=4.0
DB_MEMORY_LIMIT=4g
# Equal to DB_MEMORY_LIMIT: disable container swap for stable latency.
DB_MEMORY_SWAP_LIMIT=4g

# PostgreSQL uses shared memory for parallel queries. This remains inside the
# container memory limit above.
POSTGRES_SHM_SIZE=1g
